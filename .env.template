# crypto-quant-desk — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!
# ============================================================

# Telegram Bot Credentials (required for notifications)
# Get your bot token from @BotFather on Telegram
CQD_TG_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (numeric, e.g., 123456789)
# Get this from @userinfobot on Telegram
CQD_TG_CHAT_ID=your_chat_id_here

# Optional: Override default exchange (binance, coinbase, kraken, etc.)
# CQD_EXCHANGE=binance

# Optional: Override default timeframe (1h, 4h, 1d, etc.)
# CQD_TIMEFRAME=1h

# Optional: Wallet starting balance (USDT)
# CQD_WALLET_BALANCE=10000.0

# Optional: Override project root if not at /opt/data/cqd-trading-bot/
# CQD_PROJECT_ROOT=/opt/data/cqd-trading-bot